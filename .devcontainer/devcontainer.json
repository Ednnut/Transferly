{
  "name": "Transferly",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:1-20-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/redis:1": {}
  },
  "postCreateCommand": "npm ci --prefix api && npm ci --prefix bot && npm ci --prefix miniapp && npx --prefix miniapp playwright install --with-deps chromium",
  "forwardPorts": [3000, 5173, 6379],
  "portsAttributes": {
    "3000": { "label": "Transferly API" },
    "5173": { "label": "Transferly Mini App" },
    "6379": { "label": "Redis" }
  },
  "customizations": {
    "vscode": {
      "settings": {
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
          "source.fixAll.eslint": "explicit"
        },
        "files.exclude": {
          "**/node_modules": true,
          "**/dist": true
        }
      },
      "extensions": ["dbaeumer.vscode-eslint", "ms-playwright.playwright"]
    }
  }
}
