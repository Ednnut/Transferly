# Required for local setup
REDIS_URL=redis://localhost:6379
PAYPAL_CLIENT_ID=your-paypal-sandbox-client-id
PAYPAL_CLIENT_SECRET=your-paypal-sandbox-client-secret
PAYPAL_WEBHOOK_ID=your-paypal-webhook-id

# Common app settings
NODE_ENV=development
PORT=3000
SQLITE_DATABASE_PATH=./data/transferly.sqlite
APP_BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN_SECONDS=3600
JWT_CLOCK_SKEW_SECONDS=30
AUTH_SESSION_TTL_SECONDS=604800
ADMIN_API_TOKEN=replace-with-a-long-random-admin-token
BOT_API_HMAC_SECRET=replace-with-a-long-random-bot-api-hmac-secret
BOT_API_HMAC_REQUIRED=true
BOT_API_HMAC_MAX_AGE_MS=300000
BOT_API_HMAC_REPLAY_PROTECTION=true
BOT_API_HMAC_REPLAY_STORE=redis
BOT_API_HMAC_REPLAY_KEY_PREFIX=transferly:bot-api-replay

# PayPal
PAYPAL_ENVIRONMENT=sandbox

# Telegram Mini App
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_MINI_APP_URL=https://transferly-nine.vercel.app
MINI_APP_URL=https://transferly-nine.vercel.app

# Telegram Owner & Admin Configuration
# Set Telegram user IDs here to grant owner/admin access (numeric IDs from Telegram)
# Multiple IDs should be comma-separated
# Example: 123456789,987654321
TRANSFERLY_OWNER_TELEGRAM_USER_IDS=
TRANSFERLY_ADMIN_TELEGRAM_USER_IDS=

# Optional auth
USER_API_TOKENS=

# Optional queue/development controls
INLINE_QUEUE_MODE=false
JOB_WAIT_MS=30000

# Private generated asset storage and expiry cleanup
GENERATED_ASSET_STORAGE_PATH=./data/generated-assets
GENERATED_ASSET_MAX_BYTES=10485760
GENERATED_ASSET_CLEANUP_INTERVAL_MS=21600000
GENERATED_ASSET_CLEANUP_BATCH_SIZE=100
# Keep false until a reviewed storage reconciliation run confirms the target path.
GENERATED_ASSET_ORPHAN_DELETE_ENABLED=false
GENERATED_ASSET_DOWNLOAD_TTL_SECONDS=300
ORDER_PROCESSING_LOCK_TTL_MS=900000
POINT_RESERVATION_TTL_MS=86400000
POINT_RESERVATION_EXPIRY_INTERVAL_MS=300000
POINT_RESERVATION_EXPIRY_BATCH_SIZE=100

# Optional service rollout controls (comma-separated manifest feature flags)
SERVICE_FEATURE_FLAGS=

# Optional risk/rate-limit controls
MAX_SINGLE_PAYOUT=1000
DAILY_PAYOUT_LIMIT=5000
MAX_PAYOUTS_PER_HOUR=5
HIGH_RISK_COUNTRIES=RU,IR,KP,SY
HIGH_RISK_CURRENCIES=RUB,IRR,KPW,SYP
SUSPICIOUS_INVOICE_KEYWORDS=crypto,investment,loan,casino,gift card
API_RATE_LIMIT_MAX=120
API_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=20
AUTH_RATE_LIMIT_WINDOW_MS=60000
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://transferly-nine.vercel.app

# Optional provider integrations
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=
STRIPE_CONNECTED_ACCOUNT_ID=
STRIPE_PAYOUTS_ENABLED=false
WISE_API_TOKEN=
WISE_PROFILE_ID=
WISE_WEBHOOK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_WEBHOOK_SECRET=
CRYPTO_COMMERCE_API_KEY=
CRYPTO_COMMERCE_WEBHOOK_SECRET=
# EMAIL_DELIVERY_WEBHOOK_URL=https://example.com/email-webhook

# Optional PayPal sandbox smoke test
PAYPAL_SANDBOX_INVOICE_RECIPIENT_EMAIL=
PAYPAL_SANDBOX_PAYOUT_RECEIVER=
PAYPAL_SANDBOX_INVOICE_AMOUNT=12.50
PAYPAL_SANDBOX_PAYOUT_AMOUNT=5.00
PAYPAL_SANDBOX_CURRENCY=USD

# Optional demo seed overrides
SEED_USER_ID=demo-user
SEED_USER_EMAIL=demo@transferly.local
SEED_USER_NAME=Demo User
