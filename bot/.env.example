# --- Telegram Bot Environment -----------------------
ADMIN_TELEGRAM_ID=
# Optional. Defaults to ADMIN_TELEGRAM_ID. This account is the non-expiring OWNER.
OWNER_TELEGRAM_ID=
ADMIN_TELEGRAM_USERNAME=
BOT_TOKEN=

# If ADMIN_TELEGRAM_ID is empty, /whoami will show the numeric ID to set here.
# OWNER can manage bot users/admins. ADMIN can operate payments. USER can use services.
# ADMIN_TELEGRAM_USERNAME can be used as a local fallback, but numeric ID is safer.

# Transferly API the bot should call
API_URL=http://localhost:3000

# Telegram Mini App URL. Use the exact deployed frontend URL used by Telegram.
MINI_APP_URL=https://transferly-nine.vercel.app
# Optional comma-separated host allowlist for MINI_APP_URL in every environment.
BOT_ALLOWED_MINI_APP_HOSTS=transferly-nine.vercel.app

# Bot admin API token (must match api/ ADMIN_API_TOKEN)
ADMIN_API_TOKEN=change-me

# Required in production when the API enables bot-to-API HMAC verification.
# Must match api/ BOT_API_HMAC_SECRET. Do not reuse ADMIN_API_TOKEN.
API_HMAC_SECRET=

# Update delivery. Use polling locally; use webhook for production/PM2 behind HTTPS.
BOT_UPDATE_MODE=polling
BOT_WEBHOOK_URL=https://your-domain.example/telegram/webhook
BOT_WEBHOOK_PATH=/telegram/webhook
BOT_WEBHOOK_SECRET=replace-with-a-long-random-webhook-secret
BOT_PORT=8080

# Runtime hardening
BOT_ALLOWED_UPDATES=message,callback_query
BOT_DROP_PENDING_UPDATES=false
BOT_REQUIRE_API_READY=false
BOT_CONFIGURE_MENU_BUTTON=true
BOT_RUN_SUBSCRIPTION_ALERT_SWEEP=false
BOT_RUN_SESSION_CLEANUP=true
BOT_UPDATE_DEDUPE_TTL_MS=600000
BOT_UPDATE_DEDUPE_MAX_ENTRIES=5000
